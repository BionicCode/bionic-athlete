<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FitToCsvConverter.Main">

    <FontFamily x:Key="SegoeMDL2Assets">Segoe Fluent Icons</FontFamily>

    <Duration x:Key="MouseOverAnimationDuration">0:0:0.2</Duration>

    <Color x:Key="MouseOverTextColor">White</Color>
    <SolidColorBrush x:Key="MouseOverTextBrush"
                     Color="{StaticResource MouseOverTextColor}"
                     Opacity="1" />
    <Color x:Key="TextColor">Black</Color>
    <SolidColorBrush x:Key="TextBrush"
                     Color="{StaticResource TextColor}"
                     Opacity="1" />
    <Color x:Key="ExtraFileItemAutoRenamingEnabledBackgroundColor">#ade79c</Color>
    <SolidColorBrush x:Key="FileItemAutoRenamingEnabledBackgroundBrush"
                     Color="{StaticResource ExtraFileItemAutoRenamingEnabledBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="ExtraFileItemManualRenamingEnabledBackgroundColor">#e7d89c</Color>
    <SolidColorBrush x:Key="FileItemManualRenamingEnabledBackgroundBrush"
                     Color="{StaticResource ExtraFileItemManualRenamingEnabledBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="ExtraFileItemDefaultBackgroundColor">#9bc3c5</Color>
    <SolidColorBrush x:Key="ExtraFileItemDefaultBackgroundBrush"
                     Color="{StaticResource ExtraFileItemDefaultBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="ExtraFileItemButtonBackgroundColor">LightSteelBlue</Color>
    <Color x:Key="ExtraFileItemButtonHighlightColor">SteelBlue</Color>
    <SolidColorBrush x:Key="ExtraFileItemButtonBackgroundBrush"
                     Color="{StaticResource ExtraFileItemButtonBackgroundColor}"
                     Opacity="0.8" />

    <Style TargetType="Button"
           x:Shared="False">
        <Style.Setters>
            <Setter Property="Background"
                    Value="{StaticResource ExtraFileItemButtonBackgroundBrush}" />
            <Setter Property="Foreground"
                    Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style.Setters>

        <Style.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Setter Property="Foreground"
                        Value="{StaticResource MouseOverTextBrush}" />
            </Trigger>

            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                        To="{StaticResource ExtraFileItemButtonHighlightColor}"
                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                        To="{StaticResource ExtraFileItemButtonBackgroundColor}"
                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
