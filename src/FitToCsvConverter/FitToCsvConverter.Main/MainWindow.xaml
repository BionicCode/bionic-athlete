<Window x:Class="FitToCsvConverter.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FitToCsvConverter.Main"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>

        <DataTemplate x:Key="ExtraZipFileContentTemplate">
            <ListBox ItemsSource="{Binding Value}"
                     AllowDrop="True"
                     Drop="OnExtraZipFileContentDropped">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DataTemplate>
    </Window.Resources>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="5">
            <TextBlock Text="FIT File:" />
            <Border BorderBrush="Gray"
                    BorderThickness="1"
                    Height="100"
                    Background="Transparent"
                    IsHitTestVisible="True"
                    AllowDrop="True"
                    Drop="Border_Drop">
                <TextBlock Text="&#xe8e5;"
                           FontFamily="{StaticResource SegoeMDL2Assets}"
                           Foreground="Gray"
                           FontSize="68"
                           Opacity="0.5"
                           IsHitTestVisible="False"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>
        </StackPanel>

        <Separator Grid.Row="2" 
                   Grid.Column="0" 
                   Grid.ColumnSpan="2"
                   Margin="0,10" />

        <StackPanel Grid.Row="3"
                    Margin="5,0">
            <TextBlock Text="ZIP File Data:" />
            <DataGrid AutoGenerateColumns="False"
                      ItemsSource="{Binding ExportData}"
                      SelectedItem="{Binding SelectedExportData}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Fit File"
                                        Binding="{Binding FitFilePath}" />
                    <DataGridTemplateColumn Header="Additional Files"
                                            CellTemplate="{StaticResource ExtraZipFileContentTemplate}" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <Separator Grid.Row="4"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,10" />

        <Grid Grid.Row="5"
              Margin="5,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="DestinationFolderTextBox"
                     Grid.Column="0"
                     Text="{Binding DestinationFolder}"
                     Margin="0,0,0,0"
                     Padding="5"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Top" />
            <Button Grid.Column="1"
                    Margin="10,0,0,0"
                    VerticalAlignment="Top"
                    Height="{Binding ElementName=DestinationFolderTextBox, Path=ActualHeight}"
                    Width="80"
                    Click="SelectDestinationFolderButton_Click">
                <TextBlock Text="&#xe721;"
                           FontFamily="{StaticResource SegoeMDL2Assets}"
                           Foreground="Gray"
                           Opacity="1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Button>
        </Grid>
        
    </Grid>
</Window>
