<Window x:Class="FitToCsvConverter.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FitToCsvConverter.Main"
        xmlns:viewModel="clr-namespace:FitToCsvConverter.ViewModel;assembly=FitToCsvConverter.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <d:DesignerProperties.DataContext>
        <viewModel:MainViewModel />
    </d:DesignerProperties.DataContext>
    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="DataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding"
                    Value="50" />
        </Style>
        <DataTemplate x:Key="ExtraZipFileContentTemplate">
            <ListBox ItemsSource="{Binding SelectedExtraFilePaths}"
                     SelectedItem="{Binding SelectedExtraFilePath}"
                     AllowDrop="True"
                     Drop="OnExtraZipFileContentDropped"
                     Background="Transparent">
                <!--<ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>-->
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderThickness="1" 
                                BorderBrush="Gray"
                                Background="{StaticResource ExtraFileItemBackgroundBrush}"
                                CornerRadius="4"
                                Padding="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" 
                                           VerticalAlignment="Center" />
                                <CheckBox IsChecked="{Binding IsRenamingEnabled}"
                                          Content="Rename"
                                          Margin="5,0,20,0"
                                          VerticalAlignment="Center"
                                          ToolTip="Manually rename file to use the batch name."/>
                                <Border x:Name="ClipBorder" CornerRadius="8">
                                    <Button Content="&#xe74d;"
                                            Command="{Binding DataContext.DeleteExtraFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            FontFamily="{StaticResource SegoeMDL2Assets}"
                                            ToolTip="Remove file"
                                            Margin="5,0"
                                            Padding="3"
                                            FontSize="10" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="Margin"
                                Value="0" />
                        <Setter Property="Padding"
                                Value="0" />
                        <Setter Property="IsHitTestVisible"
                                Value="True" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DataTemplate>

        <DataTemplate x:Key="RemoveRowContentTemplate">
            <Button Content="&#xe74d;"
                    FontFamily="{StaticResource SegoeMDL2Assets}"
                    Foreground="Red"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    ToolTip="Remove row"
                    Width="30"/>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Start New Session"
                Command="{Binding StartNewSessionCommand}"
                Margin="5" />

        <Separator Grid.Row="1"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,10" />
        
        <ScrollViewer Grid.Row="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="5">
                    <TextBlock Text="FIT File:" />
                    <ListBox ItemsSource="{Binding SelectedFitFilePaths}"
                             SelectedItem="{Binding SelectedFitFilePath}"
                             AllowDrop="True"
                             ToolTip="Drag and drop FIT files here, either raw or as ZIP files."
                             Drop="OnFitFilesDropped"
                             DragEnter="PrepareFitFileDropTargetFeedBack"
                             DragOver="ProvideFitFileDropTargetFeedBack"
                             DragLeave="ClearFitFileDropTargetFeedBack">
                        <ListBox.Template>
                            <ControlTemplate TargetType="ListBox">
                                <Border BorderBrush="Gray"
                                        BorderThickness="1"
                                        Height="100"
                                        Background="Transparent"
                                        IsHitTestVisible="True"
                                        AllowDrop="True">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <TextBlock Text="&#xe8e5;"
                                                       FontFamily="{StaticResource SegoeMDL2Assets}"
                                                       Foreground="Gray"
                                                       FontSize="68"
                                                       Opacity="0.5"
                                                       IsHitTestVisible="False"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <ItemsPresenter />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ListBox.Template>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>

                <Separator Grid.Row="2"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,10" />

                <StackPanel Grid.Row="3"
                            Margin="5,0">
                    <TextBlock Text="ZIP File Data:" />
                    <DataGrid AutoGenerateColumns="False"
                              ItemsSource="{Binding ExportData}"
                              SelectedItem="{Binding SelectedExportData}">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"
                                             Color="Transparent" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}"
                                             Color="Black" />
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Fit File"
                                                IsReadOnly="True"
                                                Width="Auto"
                                                Binding="{Binding FitFilePath, Mode=OneTime}" />
                            <DataGridTemplateColumn Header="Additional Files"
                                                    CellTemplate="{StaticResource ExtraZipFileContentTemplate}"
                                                    Width="*" />
                            <DataGridCheckBoxColumn Header="Enable auto-rename"
                                                Width="Auto"
                                                Binding="{Binding IsAutoRenamingEnabled}" />
                            <DataGridTextColumn Header="Batch Name"
                                                Width="Auto"
                                                Binding="{Binding BatchName, UpdateSourceTrigger=PropertyChanged}" />
                            <DataGridTemplateColumn Header="Remove"
                                                    Width="Auto"
                                                    CellTemplate="{StaticResource RemoveRowContentTemplate}"
                                                    CellStyle="{StaticResource DataGridCellStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <Separator Grid.Row="4"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,10" />

                <Grid Grid.Row="5"
                      Margin="5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DestinationFolderTextBox"
                             Grid.Column="0"
                             Text="{Binding DestinationFolder}"
                             Margin="0,0,0,0"
                             Padding="5"
                             HorizontalAlignment="Stretch"
                             VerticalAlignment="Top" />
                    <Button Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Top"
                            Height="{Binding ElementName=DestinationFolderTextBox, Path=ActualHeight}"
                            Width="80"
                            Click="SelectDestinationFolderButton_Click">
                        <TextBlock Text="&#xe721;"
                                   FontFamily="{StaticResource SegoeMDL2Assets}"
                                   Foreground="Gray"
                                   Opacity="1"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Button>
                </Grid>

                <StackPanel Grid.Row="6"
                            Margin="0,10,0,0"
                            Visibility="{Binding IsReportingProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProgressDataCollection[0].OperationTitle}" />
                        <TextBlock Text=":" />
                    </StackPanel>
                    <Grid>
                        <ProgressBar Minimum="0"
                                     Maximum="1"
                                     Value="{Binding ProgressDataCollection[0].Progress, Mode=OneWay}"
                                     Height="20"
                                     HorizontalAlignment="Stretch" />
                        <TextBlock Text="{Binding ProgressDataCollection[0].Progress, StringFormat={}{0:P0}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold" />
                    </Grid>
                    <TextBlock Text="{Binding ProgressDataCollection[0].Message}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               FontStyle="Italic" />
                </StackPanel>

                <StackPanel Grid.Row="7"
                            Margin="0,10,0,0"
                            Visibility="{Binding IsReportingProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProgressDataCollection[1].OperationTitle}" />
                        <TextBlock Text=":" />
                    </StackPanel>
                    <Grid>
                        <ProgressBar Minimum="0"
                                     Maximum="1"
                                     Value="{Binding ProgressDataCollection[1].Progress, Mode=OneWay}"
                                     Height="20"
                                     HorizontalAlignment="Stretch" />
                        <TextBlock Text="{Binding ProgressDataCollection[1].Progress, StringFormat={}{0:P0}}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="Black"
                                   FontWeight="Bold" />
                    </Grid>
                    <TextBlock Text="{Binding ProgressDataCollection[1].Message}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               FontStyle="Italic" />
                </StackPanel>

                <Button Grid.Row="8"
                        Margin="10,120,0,0"
                        VerticalAlignment="Top"
                        Height="{Binding ElementName=DestinationFolderTextBox, Path=ActualHeight}"
                        Width="80"
                        Content="&#xe724;"
                        FontFamily="{StaticResource SegoeMDL2Assets}"
                        Foreground="Gray"
                        Opacity="1"
                        HorizontalAlignment="Right"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding ExportCommand}">
                </Button>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
