<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:BionicAthlete.Presentation">

    <FontFamily x:Key="SegoeMDL2FluentAssets">Segoe Fluent Icons</FontFamily>

    <Style x:Key="IconStyle"
           TargetType="TextBlock">
        <Setter Property="FontFamily"
                Value="{StaticResource SegoeMDL2FluentAssets}" />
        <Setter Property="Background"
                Value="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Background}" />
        <Setter Property="Foreground"
                Value="{Binding RelativeSource={RelativeSource AncestorType=Control}, Path=Foreground}" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
        <Setter Property="Opacity"
                Value="1" />
    </Style>

    <Style x:Key="IconViewBoxStyle"
           TargetType="Viewbox">
        <Setter Property="Stretch"
                Value="Uniform" />
        <Setter Property="StretchDirection"
                Value="Both" />
        <Setter Property="HorizontalAlignment"
                Value="Center" />
        <Setter Property="VerticalAlignment"
                Value="Center" />
    </Style>

    <!--#region Icons -->
    <Viewbox x:Key="SearchIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Style="{StaticResource IconStyle}"
                   Text="&#xe721;" />
    </Viewbox>
    <Viewbox x:Key="SendIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Style="{StaticResource IconStyle}"
                   Text="&#xe724;" />
    </Viewbox>
    <Viewbox x:Key="ClearIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Style="{StaticResource IconStyle}"
                   Text="&#xe894;" />
    </Viewbox>
    <Viewbox x:Key="DeleteIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Style="{StaticResource IconStyle}"
                   Text="&#xe74d;" />
    </Viewbox>
    <Viewbox x:Key="OpenFileIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Style="{StaticResource IconStyle}"
                   Text="&#xe8e5;"
                   ToolTip="Open file" />
    </Viewbox>

    <Grid x:Key="FitFileDropTargetIcon"
          x:Shared="False"
          Opacity="0.3"
          IsHitTestVisible="False"
          ToolTip="Drag and drop FIT files here, either raw or contained in ZIP files.">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <!--<Viewbox Grid.Row="0"-->
                 <!--StretchDirection="Both">-->
            <ContentControl Grid.Row="0" Content="{StaticResource OpenFileIcon}" />
        <!--</Viewbox>-->
        <TextBlock Grid.Row="1"
                   Text="Drop FIT files or"
                   FontStyle="Italic"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Row="2"
                   Text="ZIP archives containing FIT files here"
                   FontStyle="Italic"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>

    <Grid x:Key="ExtraFilesDropTargetIcon"
          x:Shared="False"
          Opacity="0.3"
          IsHitTestVisible="False"
          ToolTip="Drag and drop additional files here that should be included in the exported ZIP archive.">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Viewbox Grid.Row="0"
                 StretchDirection="Both">
            <ContentControl Content="{StaticResource OpenFileIcon}" />
        </Viewbox>
        <TextBlock Grid.Row="1"
                   Text="Drop additional files here"
                   FontStyle="Italic"
                   FontSize="18"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </Grid>
    <!--#endregion Icons-->

    <Viewbox x:Key="ChevronLeftIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Text="&#xE973;"
                   Style="{StaticResource IconStyle}" />
    </Viewbox>

    <Viewbox x:Key="ChevronRightIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Text="&#xE974;"
                   Style="{StaticResource IconStyle}" />
    </Viewbox>

    <Viewbox x:Key="GotoTodayIcon"
             Style="{StaticResource IconViewBoxStyle}"
             x:Shared="False">
        <TextBlock Text="&#xE8D1;"
                   Style="{StaticResource IconStyle}" />
    </Viewbox>

</ResourceDictionary>