<Window x:Class="FitToCsvConverter.Controls.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FitToCsvConverter.Controls"
        xmlns:viewModel="clr-namespace:FitToCsvConverter.ViewModel;assembly=FitToCsvConverter.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" 
        SizeToContent="Width"
        SnapsToDevicePixels="True">
    <d:DesignerProperties.DataContext>
        <viewModel:MainViewModel />
    </d:DesignerProperties.DataContext>
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/ViewRessources.xaml" />
                <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/FlipSwitchToggleButtonStyle.xaml" />
                <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/ScrollBarStyle.xaml" />
                <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/WatermarkTextBoxStyle.xaml" />
                <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/ProgressbarStyle.xaml" />
                <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/ToolBarButtonStyle.xaml" />
                <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/UniformToolBarStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <local:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <Style  x:Key="LabelTextBlockStyle"
                    TargetType="TextBlock">
                <Setter Property="FontSize"
                        Value="14" />
                <Setter Property="FontWeight"
                        Value="Bold" />
                <Setter Property="HorizontalAlignment"
                        Value="Left" />
                <Setter Property="VerticalAlignment"
                        Value="Top" />
            </Style>
            
            <Style  x:Key="FieldListStyle"
                    TargetType="ListBox">
                <Style.Resources>
                    <Style x:Key="FieldListItemStyle"
                           TargetType="ListBoxItem">
                        <Setter Property="Background"
                                Value="Transparent" />
                        <Setter Property="BorderBrush"
                                Value="Transparent" />
                        <Setter Property="BorderThickness"
                                Value="0" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />
                        <Setter Property="Padding"
                                Value="0" />
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch" />
                        <Setter Property="HorizontalAlignment"
                                Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Style.Resources>

                <Setter Property="ItemContainerStyle"
                        Value="{StaticResource FieldListItemStyle}" />
                <Setter Property="Height"
                        Value="200" />
                <!--<Setter Property="Width"
                        Value="230" />-->
                <Setter Property="BorderThickness"
                        Value="0" />
                <Setter Property="HorizontalContentAlignment"
                        Value="Stretch" />
                <Setter Property="HorizontalAlignment"
                        Value="Stretch" />
                <Setter Property="ItemTemplate">
                    <Setter.Value>
                        <DataTemplate DataType="{x:Type viewModel:DataField}">
                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                      Content="{Binding Name, Mode=OneTime}"
                                      VerticalAlignment="Center"
                                      Margin="0,0,5,0" />
                        </DataTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListBoxItem" 
                   x:Key="ExtraFileListBoxItem">
                <Setter Property="Background"
                        Value="{StaticResource DefaultListItemBackgroundBrush}" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="BorderBrush"
                        Value="Gray" />
                <Setter Property="Margin"
                        Value="5,0" />
                <Setter Property="Padding"
                        Value="5,2" />
                <Setter Property="IsHitTestVisible"
                        Value="True" />
                <Setter Property="HorizontalContentAlignment"
                        Value="Stretch" />
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>

                            <ControlTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsRenamingEnabled}"
                                             Value="True">
                                    <Setter Property="Background"
                                            Value="{StaticResource FileItemManualRenamingEnabledBackgroundBrush}" />
                                </DataTrigger>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsRenamingEnabled}"
                                                   Value="False" />
                                        <Condition Binding="{Binding DataContext.IsAutoRenamingEnabled, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                   Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Background"
                                            Value="{StaticResource FileItemAutoRenamingEnabledBackgroundBrush}" />
                                </MultiDataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListBoxItem">
                <Setter Property="Background"
                        Value="{StaticResource DefaultListItemBackgroundBrush}" />
                <Setter Property="BorderThickness"
                        Value="1" />
                <Setter Property="BorderBrush"
                        Value="Gray" />
                <Setter Property="Margin"
                        Value="5,0" />
                <Setter Property="Padding"
                        Value="5,2" />
                <Setter Property="IsHitTestVisible"
                        Value="True" />
                <Setter Property="HorizontalContentAlignment"
                        Value="Stretch" />
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self}, Path=Content}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{StaticResource DefaultListItemHighlightBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="DataGridCellStyle"
                   TargetType="DataGridCell">
                <Setter Property="Padding"
                        Value="50" />
            </Style>

            <ContextMenu x:Key="ActivityFieldContextMenu" DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                <MenuItem Header="Select all"
                          Command="{x:Static local:MainWindow.SelectAllActivityFieldsCommand}" />
                <MenuItem Header="Deselect all"
                          Command="{x:Static local:MainWindow.UnselectAllActivityFieldsCommand}" />
            </ContextMenu>

            <ContextMenu x:Key="RecordFieldContextMenu"
                         DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                <MenuItem Header="Select all"
                          Command="{x:Static local:MainWindow.SelectAllRecordFieldsCommand}" />
                <MenuItem Header="Deselect all"
                          Command="{x:Static local:MainWindow.UnselectAllRecordFieldsCommand}" />
            </ContextMenu>

            <ContextMenu x:Key="SessionFieldContextMenu"
                         DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                <MenuItem Header="Select all"
                          Command="{x:Static local:MainWindow.SelectAllSessionFieldsCommand}" />
                <MenuItem Header="Deselect all"
                          Command="{x:Static local:MainWindow.UnselectAllSessionFieldsCommand}" />
            </ContextMenu>

            <ContextMenu x:Key="LapFieldContextMenu"
                         DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                <MenuItem Header="Select all"
                          Command="{x:Static local:MainWindow.SelectAllLapFieldsCommand}" />
                <MenuItem Header="Deselect all"
                          Command="{x:Static local:MainWindow.UnselectAllLapFieldsCommand}" />
            </ContextMenu>

            <ContextMenu x:Key="ZipFilesContextMenu"
                         DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.DataContext}">
                <MenuItem Header="Select all for rename"
                          Command="{x:Static local:MainWindow.SelectAllExtraFilesForRenameCommand}" />
                <MenuItem Header="Deselect all for rename"
                          Command="{x:Static local:MainWindow.UnselectAllExtraFilesForRenameCommand}" />
            </ContextMenu>

            <ContextMenu x:Key="FitFileListContextMenu"
                         DataContext="{Binding RelativeSource={RelativeSource Self}, Path=PlacementTarget.SelectedItem}">
                <MenuItem Header="Remove FIT file"
                          Command="{x:Static local:MainWindow.RemoveFitFileCommand}"
                          CommandParameter="{Binding}" />
                <MenuItem Header="Add FIT file"
                          Command="{x:Static local:MainWindow.AddFitFileCommand}" />
            </ContextMenu>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Button Grid.Row="0"
                Content="Start New Session"
                Command="{Binding StartNewSessionCommand}"
                Margin="5" />

        <Separator Grid.Row="1"
                   Grid.Column="0"
                   Grid.ColumnSpan="2"
                   Margin="0,10" />

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--<StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Margin="5">
                    <TextBlock Text="FIT File:"
                               Style="{StaticResource LabelTextBlockStyle}" />
                    <ListBox ItemsSource="{Binding FitFilePaths}"
                             SelectedItem="{Binding SelectedFitFilePath}"
                             Background="Transparent"
                             BorderBrush="Gray"
                             BorderThickness="1"
                             Height="100"
                             Padding="0,5"
                             AllowDrop="True"
                             ToolTip="Drag and drop FIT files here, either raw or as ZIP files."
                             Drop="OnFitFilesDropped"
                             DragEnter="PrepareFitFileDropTargetFeedBack"
                             DragOver="ProvideFitFileDropTargetFeedBack"
                             DragLeave="ClearFitFileDropTargetFeedBack"
                             ContextMenu="{StaticResource FitFileListContextMenu}">
                        <ListBox.Template>
                            <ControlTemplate TargetType="ListBox">
                                <Border BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        Padding="{TemplateBinding Padding}"
                                        Background="{TemplateBinding Background}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <ContentControl Content="{StaticResource FitFileDropTargetIcon}" />
                                            <ItemsPresenter />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </ControlTemplate>
                        </ListBox.Template>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>-->

                <Separator Grid.Row="2"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,10" />

                <Grid Grid.Row="3"
                      Margin="5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="FIT Files:"
                                   Style="{StaticResource LabelTextBlockStyle}" />
                        <local:UniformToolBar Grid.Row="1"
                                              Margin="0,0,0,5"
                                              Orientation="Vertical"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Top"
                                              ItemWidth="59"
                                              ItemHeight="28">
                            <!--<Button Content="Hello" Style="{x:Null}" />
                            <Button Content="World"
                                    Style="{x:Null}" />
                            <Button Content="Hello"
                                    Style="{x:Null}" />
                            <Button Content="World"
                                    Style="{x:Null}" />
                            <Button Content="Hello"
                                    Style="{x:Null}" />
                            <Button Content="World"
                                    Style="{x:Null}" />-->
                            <local:ToolBarButton Content="{StaticResource OpenFileIcon}"
                                                 LabelText="Open file"
                                                 Command="{Binding OpenFitFileCommand}"
                                                 CommandParameter="{Binding SelectedExportData}"
                                                 LabelFontSize="12"/>
                            <local:ToolBarButton Content="{StaticResource DeleteIcon}"
                                                 LabelText="Clear all"
                                                 Command="{Binding RemoveFitFileCommand}"
                                                 CommandParameter="{Binding SelectedExportData}"
                                                 LabelFontSize="12"/>
                        </local:UniformToolBar>
                            <Grid
                                                      Grid.Row="2">
                                <ContentControl Content="{StaticResource FitFileDropTargetIcon}"
                                                Height="120"
                                                VerticalAlignment="Center" />
                                <Border x:Name="ToolBarSubMenuBorder"
                                        Background="Transparent"
                                        BorderBrush="Black"
                                        BorderThickness="1"
                                        RenderOptions.ClearTypeHint="Enabled">
                                    <ListBox x:Name="ExportDataMasterView"
                                             ItemsSource="{Binding ExportData, Mode=OneTime}"
                                             SelectedItem="{Binding SelectedExportData}"
                                             DisplayMemberPath="FitFileName"
                                             Background="Transparent"
                                             BorderThickness="1"
                                             Padding="0,5"
                                             Width="Auto"
                                             AllowDrop="True"
                                             ToolTip="Drag and drop FIT files here, either raw or as ZIP files."
                                             Drop="OnFitFilesDropped"
                                             DragEnter="PrepareFitFileDropTargetFeedBack"
                                             DragOver="ProvideFitFileDropTargetFeedBack"
                                             DragLeave="ClearFitFileDropTargetFeedBack"
                                             ContextMenu="{StaticResource FitFileListContextMenu}" />
                                </Border>
                            </Grid>
                    </Grid>
                    <GridSplitter Grid.Column="1"
                                  Grid.RowSpan="2"
                                  Width="8"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Stretch" />

                    <Grid Grid.Row="0"
                          Grid.Column="2"
                          Margin="10,0,0,10"
                          Visibility="{Binding ElementName=ExportDataMasterView, Path=HasItems, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Available Activity Fields:"
                                       Style="{StaticResource LabelTextBlockStyle}" />
                            <ListBox ItemsSource="{Binding SelectedExportData.ActivityFields}"
                                     Style="{StaticResource FieldListStyle}"
                                     ContextMenu="{StaticResource ActivityFieldContextMenu}" />

                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Stretch">
                            <TextBlock Text="Available Session Fields:"
                                       Style="{StaticResource LabelTextBlockStyle}" />
                            <ListBox ItemsSource="{Binding SelectedExportData.SessionFields}"
                                     Style="{StaticResource FieldListStyle}"
                                     ContextMenu="{StaticResource SessionFieldContextMenu}" />
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Available Record Fields:"
                                       Style="{StaticResource LabelTextBlockStyle}" />
                            <ListBox ItemsSource="{Binding SelectedExportData.RecordFields}"
                                     Style="{StaticResource FieldListStyle}"
                                     ContextMenu="{StaticResource RecordFieldContextMenu}" />
                        </StackPanel>

                        <StackPanel Grid.Column="3">
                            <TextBlock Text="Available Lap Fields:"
                                       Style="{StaticResource LabelTextBlockStyle}" />
                            <ListBox ItemsSource="{Binding SelectedExportData.LapFields}"
                                     Style="{StaticResource FieldListStyle}"
                                     ContextMenu="{StaticResource LapFieldContextMenu}" />
                        </StackPanel>
                        
                        <Separator Grid.Row="1"
                                   Grid.Column="0"
                                   Grid.ColumnSpan="4"
                                   Margin="0,10" />
                    </Grid>

                    <Grid Grid.Column="2"
                          Grid.Row="1"
                          Margin="10,0"
                          Visibility="{Binding ElementName=ExportDataMasterView, Path=HasItems, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <ContentControl Grid.Column="0"
                                        Grid.Row="2"
                                        Grid.RowSpan="2"
                                        Content="{StaticResource ExtraFilesDropTargetIcon}" />
                        
                        <TextBlock Grid.Row="0"
                                   Text="ZIP File Data:"
                                   Style="{StaticResource LabelTextBlockStyle}" />
                        <Separator Grid.Row="1"
                                   Grid.Column="0"
                                   Margin="0,2,0,8" />
                        <ListBox Grid.Row="2"
                                 Grid.RowSpan="2"
                                 Grid.Column="0"
                                 Height="150"
                                 Width="500"
                                 ItemsSource="{Binding SelectedExportData.SelectedExtraFilePaths}"
                                 SelectedItem="{Binding SelectedExtraFilePath}"
                                 ItemContainerStyle="{StaticResource ExtraFileListBoxItem}"
                                 BorderThickness="0"
                                 AllowDrop="True"
                                 Drop="OnExtraZipFileContentDropped"
                                 DragEnter="PrepareExtraFileDropTargetFeedBack"
                                 DragOver="ProvideExtraFileDropTargetFeedBack"
                                 DragLeave="ClearExtraFileDropTargetFeedBack"
                                 Background="Transparent"
                                 ToolTip="Drag and drop FIT files here, either raw or as ZIP files.">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Stretch" />
                                        <CheckBox x:Name="ManualRenameCheckBox"
                                                  Grid.Column="1"
                                                  IsChecked="{Binding IsRenamingEnabled}"
                                                  Foreground="{StaticResource TextBrush}"
                                                  Content="Rename"
                                                  Margin="5,0,20,0"
                                                  VerticalAlignment="Center"
                                                  ToolTip="Manually rename file to use the batch name." />
                                        <Separator Grid.Column="2"
                                                   Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                                   Margin="2"
                                                   Background="Black"/>
                                        <Button Grid.Column="3"
                                                Content="{StaticResource DeleteIcon}"
                                                Command="{Binding DeleteExtraFileCommand}"
                                                CommandParameter="{Binding}"
                                                FontFamily="{StaticResource SegoeMDL2Assets}"
                                                ToolTip="Remove file"
                                                Margin="5,0"
                                                Padding="3"
                                                FontSize="10" />
                                    </Grid>

                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=ManualRenameCheckBox, Path=IsMouseOver}"
                                                     Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ManualRenameCheckBox"
                                                                        Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)"
                                                                        To="{StaticResource MouseOverTextColor}"
                                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="ManualRenameCheckBox"
                                                                        Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)"
                                                                        To="{StaticResource TextColor}"
                                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Separator Grid.Row="0"
                                   Grid.RowSpan="4"
                                   Grid.Column="1" 
                                   Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="10,0"/>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="2"
                                   Text="Auto Rename:"
                                   Style="{StaticResource LabelTextBlockStyle}" />
                        <Separator Grid.Row="1"
                                   Grid.Column="2"
                                   Margin="0,2,0,8" />
                        <ToggleButton Grid.Row="2"
                                      Grid.Column="2"
                                      IsChecked="{Binding SelectedExportData.IsAutoRenamingEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource FlipSwitchToggleButtonStyle}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top" />

                        <Separator Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Grid.Column="3"
                                   Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="10,0" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="4"
                                   Text="Include FIT file:"
                                   Style="{StaticResource LabelTextBlockStyle}" />
                        <Separator Grid.Row="1"
                                   Grid.Column="4"
                                   Margin="0,2,0,8" />
                        <ToggleButton Grid.Row="2"
                                      Grid.Column="4"
                                      IsChecked="{Binding SelectedExportData.IsIncludeFitFileEnabled, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource FlipSwitchToggleButtonStyle}"
                                      HorizontalAlignment="Left"
                                      VerticalAlignment="Top" />

                        <Separator Grid.Row="0"
                                   Grid.RowSpan="3"
                                   Grid.Column="5"
                                   Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Margin="10,0" />

                        <TextBlock Grid.Row="0"
                                   Grid.Column="6"
                                   Text="Batch Name:"
                                   Style="{StaticResource LabelTextBlockStyle}" />
                        <Separator Grid.Row="1"
                                   Grid.Column="6"
                                   Margin="0,2,0,8" />
                        <local:WatermarkTextBox Grid.Row="2"
                                                Watermark="Enter batch name..."
                                                Grid.Column="6"
                                                Text="{Binding SelectedExportData.BatchName, UpdateSourceTrigger=PropertyChanged}"
                                                TextWrapping="Wrap"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top"
                                                Width="250"
                                                Padding="4"
                                                Margin="0" />
                    </Grid>
                </Grid>

                <Separator Grid.Row="4"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           Margin="0,10" />

                <StackPanel Grid.Row="5"
                            Margin="5,0">
                    <TextBlock Text="Destination Folder:"
                               Style="{StaticResource LabelTextBlockStyle}" />
                    <Grid Grid.Row="5"
                          Margin="5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <local:WatermarkTextBox x:Name="DestinationFolderTextBox"
                                                Grid.Column="0"
                                                Watermark="Select destination folder..."
                                                Text="{Binding DestinationFolder}"
                                                Margin="0,0,0,0"
                                                Padding="4"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Top" />
                        <Button Grid.Column="1"
                                Margin="10,0,0,0"
                                VerticalAlignment="Top"
                                Height="{Binding ElementName=DestinationFolderTextBox, Path=ActualHeight}"
                                Width="80"
                                Content="{StaticResource SearchIcon}"
                                Click="SelectDestinationFolderButton_Click" />

                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="6"
                            Margin="0,20,0,0"
                            Visibility="{Binding HasProgressData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Separator Margin="0,20" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProgressDataCollection[0].OperationTitle}" />
                        <TextBlock Text=":" />
                    </StackPanel>
                    <local:AdvancedProgressBar Maximum="1"
                                               Height="42"
                                               CornerRadius="{StaticResource CornerRadius}"
                                               ProgressTextAlignment="BottomCenter"
                                               ProgressTextSize="18"
                                               Value="{Binding ProgressDataCollection[0].Progress, Mode=OneWay}"
                                               HorizontalAlignment="Stretch"
                                               IsIndeterminate="false" />
                    <TextBlock Text="{Binding ProgressDataCollection[0].Message}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               FontStyle="Italic" />
                </StackPanel>

                <StackPanel Grid.Row="7"
                            Margin="0,0,0,20"
                            Visibility="{Binding HasProgressData, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Separator Margin="50,20" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ProgressDataCollection[1].OperationTitle}" />
                        <TextBlock Text=":" />
                    </StackPanel>
                    <local:AdvancedProgressBar Maximum="1"
                                               Height="42"
                                               CornerRadius="{StaticResource CornerRadius}"
                                               ProgressTextAlignment="BottomCenter"
                                               ProgressTextSize="18"
                                               Value="{Binding ProgressDataCollection[1].Progress, Mode=OneWay}"
                                               HorizontalAlignment="Stretch"
                                               IsIndeterminate="false" />
                    <TextBlock Text="{Binding ProgressDataCollection[1].Message}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="Gray"
                               FontStyle="Italic" />
                </StackPanel>

                <Button Grid.Row="8"
                        Margin="10,120,0,0"
                        VerticalAlignment="Top"
                        Height="{Binding ElementName=DestinationFolderTextBox, Path=ActualHeight}"
                        Width="80"
                        Content="{StaticResource SendIcon}"
                        Opacity="1"
                        HorizontalAlignment="Left"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Command="{Binding ExportCommand}">
                </Button>
            </Grid>
        </ScrollViewer>
    </Grid>
</Window>
