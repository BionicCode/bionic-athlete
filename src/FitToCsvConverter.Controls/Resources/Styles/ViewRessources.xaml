<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FitToCsvConverter.Controls"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Constants.xaml" />
        <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <local:CornerRadiusToDoubleConverter x:Key="CornerRadiusToDoubleConverter" />

    <Style TargetType="Button">
        <Style.Setters>
            <Setter Property="Background"
                    Value="{StaticResource DarkThemeButtonBackgroundBrush}" />
            <Setter Property="Foreground"
                    Value="{StaticResource DarkThemeTextBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="5" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="{StaticResource CornerRadius}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentPresenter"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}"
                                              RenderTransformOrigin="0.5,0.5"
                                              TextElement.Foreground="{TemplateBinding Foreground}">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="ContentScaleTransform"
                                                    ScaleX="1"
                                                    ScaleY="1" />
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeHoveredButtonBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeHoveredButtonTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="ContentScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="{StaticResource ButtonMouseHoverScaleFactor}"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="ContentScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="{StaticResource ButtonMouseHoverScaleFactor}"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeHoveredButtonBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeHoveredButtonTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="ContentScaleTransform"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             From="{StaticResource ButtonMouseHoverScaleFactor}"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="ContentScaleTransform"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             From="{StaticResource ButtonMouseHoverScaleFactor}"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemePressedButtonBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemePressedButtonTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemePressedButtonBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemePressedButtonTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeDisabledButtonBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeDisabledButtonTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeDisabledButtonBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeDisabledButtonTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style.Setters>
    </Style>

    <Style TargetType="CheckBox">
        <Style.Resources>
            <Style x:Key="OptionMarkFocusVisual">
                <Setter Property="Control.Template">
                    <Setter.Value>
                        <ControlTemplate>
                            <Rectangle Margin="14,0,0,0"
                                       StrokeDashArray="1 2"
                                       Stroke="#007ACC"
                                       SnapsToDevicePixels="true"
                                       StrokeThickness="1" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>

        <Style.Setters>
            <Setter Property="Background"
                    Value="{StaticResource DarkThemeCheckBoxBackgroundBrush}" />
            <Setter Property="Foreground"
                    Value="{StaticResource DarkThemeTextBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="Padding"
                    Value="5" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid x:Name="templateRoot"
                              Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CheckBoxBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    Margin="1"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                                <Grid x:Name="MarkGrid">
                                    <Path x:Name="OptionMark"
                                          Data="F1 M 9.97498,1.22334L 4.6983,9.09834L 4.52164,9.09834L 0,5.19331L 1.27664,3.52165L 4.255,6.08833L 8.33331,1.52588e-005L 9.97498,1.22334 Z "
                                          Fill="{TemplateBinding Foreground}"
                                          Margin="1"
                                          Opacity="0"
                                          Stretch="None" />
                                    <Rectangle x:Name="IndeterminateMark"
                                               Fill="{TemplateBinding Foreground}"
                                               Margin="2"
                                               Opacity="0" />
                                </Grid>
                            </Border>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Grid.Column="1"
                                              Focusable="False"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              RecognizesAccessKey="True"
                                              SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused"
                                     Value="True">
                                <Setter Property="FocusVisualStyle"
                                        Value="{StaticResource OptionMarkFocusVisual}" />
                            </Trigger>
                            <Trigger Property="HasContent"
                                     Value="true">
                                <Setter Property="FocusVisualStyle"
                                        Value="{StaticResource OptionMarkFocusVisual}" />
                                <Setter Property="Padding"
                                        Value="4,-1,0,0" />
                            </Trigger>
                            <Trigger Property="IsEnabled"
                                     Value="False">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeDisabledCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeDisabledCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="OptionMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeDisabledCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="IndeterminateMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeDisabledCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeDisabledCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeDisabledCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="OptionMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeDisabledCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="IndeterminateMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeDisabledCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeHoveredCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeHoveredCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="OptionMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeHoveredCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="IndeterminateMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeHoveredCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeHoveredCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeHoveredCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="OptionMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeHoveredCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="IndeterminateMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeHoveredCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemePressedCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemePressedCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="OptionMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemePressedCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="IndeterminateMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemePressedCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemePressedCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="ContentPresenter"
                                                            Storyboard.TargetProperty="(TextElement.Foreground).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemePressedCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="OptionMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemePressedCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <ColorAnimation Storyboard.TargetName="IndeterminateMark"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemePressedCheckBoxTextColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="OptionMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="OptionMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsChecked"
                                     Value="{x:Null}">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            To="{StaticResource DarkThemeCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="OptionMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="CheckBoxBorder"
                                                            Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                                            From="{StaticResource DarkThemeCheckBoxBackgroundColor}"
                                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="OptionMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateMark"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MouseOverAnimationDuration}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style.Setters>
    </Style>
</ResourceDictionary>
