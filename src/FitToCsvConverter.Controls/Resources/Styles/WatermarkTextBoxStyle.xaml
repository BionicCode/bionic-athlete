<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FitToCsvConverter.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Constants.xaml" />
        <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Icons.xaml" />
        <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/ViewRessources.xaml" />
            <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/ScrollBarStyle.xaml" />
        <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Colors.xaml" />
        </ResourceDictionary.MergedDictionaries>

        <Style TargetType="{x:Type local:WatermarkTextBox}">
        <Setter Property="BorderThickness"
                Value="1" />
            <Setter Property="WatermarkForeground"
                Value="{DynamicResource WatermarkTextBrush}" />
        <Setter Property="Foreground"
                Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush"
                Value="#ced4da" />
        <Setter Property="Background"
                Value="White" />
        <Setter Property="Padding"
                Value="6" />
        <Setter Property="FontSize"
                Value="16" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:WatermarkTextBox}">
                    <Border BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="6"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ContentControl x:Name="PART_WatermarkHost"
                                            Panel.ZIndex="0"
                                            Foreground="{TemplateBinding WatermarkForeground}"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"
                                            Focusable="False" />
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Panel.ZIndex="1"
                                          VerticalAlignment="Center" />

                            <Button x:Name="PART_ClearButton" 
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Content="{StaticResource ClearIcon}"
                                    Command="{x:Static local:WatermarkTextBox.ClearCommand}"
                                    Foreground="Black"
                                    Background="Transparent"
                                    BorderBrush="Transparent"
                                    ToolTip="Remove all"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    HorizontalAlignment="Right"
                                    Padding="5"
                                    Margin="5,0" />
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Text"
                                 Value="">
                            <Setter TargetName="PART_WatermarkHost"
                                    Property="Content"
                                    Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Watermark}" />
                            <Setter TargetName="PART_ClearButton"
                                    Property="Visibility"
                                    Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Text"
                                 Value="{x:Null}">
                            <Setter TargetName="PART_ClearButton"
                                    Property="Visibility"
                                    Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>