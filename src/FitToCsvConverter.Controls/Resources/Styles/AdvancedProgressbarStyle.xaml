<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FitToCsvConverter.Controls">

    <!--<Style TargetType="ProgressBar">
    </Style>-->

    <SolidColorBrush x:Key="ProgressBar.Progress"
                     Color="Yellow" />
    <SolidColorBrush x:Key="ProgressBar.Completed"
                     Color="LightGreen" />
    <SolidColorBrush x:Key="ProgressBar.Background" Color="#FFE6E6E6"/>
    <SolidColorBrush x:Key="ProgressBar.Border" Color="#FFBCBCBC"/>

    <local:ProgressTextAlignmentToGridColumnConverter x:Key="ProgressTextAlignmentToGridColumnConverter" />
    <local:ProgressTextAlignmentToGridRowConverter x:Key="ProgressTextAlignmentToGridRowConverter" />
    <local:SizeToRectConverter x:Key="SizeToRectConverter" />

    <Style x:Key="{x:Type local:AdvancedProgressBar}" 
           TargetType="{x:Type local:AdvancedProgressBar}">
        <Setter Property="Foreground" Value="{StaticResource ProgressBar.Progress}"/>
        <Setter Property="Background" Value="{StaticResource ProgressBar.Background}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ProgressBar.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:AdvancedProgressBar}">
                    <Grid x:Name="TemplateRoot">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Determinate" />
                                <VisualState x:Name="Indeterminate">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Animation"
                                                                       Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)">
                                            <EasingDoubleKeyFrame KeyTime="0"
                                                                  Value="0.25" />
                                            <EasingDoubleKeyFrame KeyTime="0:0:1"
                                                                  Value="0.25" />
                                            <EasingDoubleKeyFrame KeyTime="0:0:2"
                                                                  Value="0.25" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <PointAnimationUsingKeyFrames Storyboard.TargetName="Animation"
                                                                      Storyboard.TargetProperty="(UIElement.RenderTransformOrigin)">
                                            <EasingPointKeyFrame KeyTime="0"
                                                                 Value="-0.5,0.5" />
                                            <EasingPointKeyFrame KeyTime="0:0:1"
                                                                 Value="0.5,0.5" />
                                            <EasingPointKeyFrame KeyTime="0:0:2"
                                                                 Value="1.5,0.5" />
                                        </PointAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Title, StringFormat={}{0}:}"
                                   Foreground="{TemplateBinding TitleBrush}"
                                   FontSize="{TemplateBinding TitleSize}"
                                   FontWeight="Bold" />
                        
                        <Grid x:Name="ProgressBarHost"
                              Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" />

                            <Rectangle x:Name="PART_Track"
                                       Grid.Row="1"
                                       Grid.Column="1"
                                       RadiusX="{TemplateBinding CornerRadius}"
                                       RadiusY="{TemplateBinding CornerRadius}" />

                            <!--<Border
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="0"
                                    ClipToBounds="True">-->
                                <Grid x:Name="PART_Indicator" Grid.Row="1"
                                    Grid.Column="1"
                                      ClipToBounds="true"
                                      HorizontalAlignment="Left">
                                    <Rectangle x:Name="Indicator"
                                               Fill="{TemplateBinding Foreground}"
                                               RadiusX="{TemplateBinding CornerRadius}"
                                               RadiusY="{TemplateBinding CornerRadius}" />
                                    <Rectangle x:Name="Animation"
                                               Fill="{TemplateBinding Foreground}"
                                               RenderTransformOrigin="0.5,0.5"
                                               RadiusX="{TemplateBinding CornerRadius}"
                                               RadiusY="{TemplateBinding CornerRadius}">
                                        <!--<Rectangle.Clip>
                                            <RectangleGeometry Rect="{Binding ElementName=PART_Indicator, Path=RenderSize, Converter={StaticResource SizeToRectConverter}}"
                                                               RadiusX="34"
                                                               RadiusY="34" />
                                        </Rectangle.Clip>-->
                                        <Rectangle.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform />
                                                <SkewTransform />
                                                <RotateTransform />
                                                <TranslateTransform />
                                            </TransformGroup>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                </Grid>
                            <!--</Border>-->
                            <TextBlock Grid.Row="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ProgressPercentageAlignment, Converter={StaticResource ProgressTextAlignmentToGridRowConverter}}"
                                       Grid.Column="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ProgressPercentageAlignment, Converter={StaticResource ProgressTextAlignmentToGridColumnConverter}}"
                                       Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ProgressPercentage, StringFormat={}{0:F0} %}"
                                       Foreground="{TemplateBinding ProgressPercentageBrush}"
                                       FontSize="{TemplateBinding ProgressPercentageSize}"
                                       FontWeight="Bold"
                                       Margin="5"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center" />
                        </Grid>
                        
                        <TextBlock Grid.Row="2"
                                   Text="{TemplateBinding ProgressMessage}"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   FontSize="{TemplateBinding ProgressMessageSize}"
                                   Foreground="{TemplateBinding ProgressMessageBrush}"
                                   FontStyle="Italic" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter Property="LayoutTransform" TargetName="TemplateRoot">
                                <Setter.Value>
                                    <RotateTransform Angle="-90"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsIndeterminate" Value="true">
                            <Setter Property="Visibility"
                                    TargetName="Indicator" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ProgressPercentage"
                                 Value="100">
                            <Setter Property="Foreground"
                                    Value="{StaticResource ProgressBar.Completed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>