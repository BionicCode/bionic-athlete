<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FitToCsvConverter.Controls">

    <Style x:Key="{x:Static local:UniformToolBar.UniformToolBarMainPanelStyleKey}"
           TargetType="{x:Type local:UniformToolBarPanel}">
        <Style.Triggers>
            <Trigger Property="Orientation"
                     Value="Vertical">
                <Setter Property="Margin"
                        Value="0" />
            </Trigger>
        </Style.Triggers>
    </Style>

