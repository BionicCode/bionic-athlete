<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <Duration x:Key="MouseOverAnimationDuration">0:0:0.3</Duration>
    <CornerRadius x:Key="CornerRadius">4</CornerRadius>
    <system:Double x:Key="CornerRadiusDouble">4</system:Double>
    <system:Double x:Key="ButtonMouseHoverScaleFactor">0.75</system:Double>
    <system:Double x:Key="ToolButtonFontSize">10</system:Double>
    <FontStretch x:Key="ToolButtonFontStretch">UltraExpanded</FontStretch>
    <FontWeight  x:Key="ToolButtonFontWeight">Light</FontWeight>
</ResourceDictionary>