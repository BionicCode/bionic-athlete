<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FitToCsvConverter.Controls">

    <FontFamily x:Key="SegoeMDL2Assets">Segoe Fluent Icons</FontFamily>
    <!--#region Icons -->
    <TextBlock x:Key="SearchIcon"
               x:Shared="False"
               Text="&#xe721;"
               FontFamily="{StaticResource SegoeMDL2Assets}"
               Opacity="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
    <TextBlock x:Key="SendIcon"
               x:Shared="False"
               Text="&#xe724;"
               FontFamily="{StaticResource SegoeMDL2Assets}"
               Opacity="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
    <TextBlock x:Key="ClearIcon"
               x:Shared="False"
               Text="&#xe894;"
               FontFamily="{StaticResource SegoeMDL2Assets}"
               Opacity="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
    <TextBlock x:Key="DeleteIcon"
               x:Shared="False"
               Text="&#xe74d;"
               FontFamily="{StaticResource SegoeMDL2Assets}"
               Opacity="1"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />
    <TextBlock x:Key="OpenFileIcon"
               x:Shared="False"
               Text="&#xe8e5;"
               ToolTip="Open file"
               FontFamily="{StaticResource SegoeMDL2Assets}"
               FontSize="{Binding RelativeSource={RelativeSource AncestorType=ContentControl}, Path=FontSize}"
               Opacity="0.5"
               IsHitTestVisible="False"
               HorizontalAlignment="Center"
               VerticalAlignment="Center" />

    <StackPanel x:Key="DropTargetIcon"
                x:Shared="False"
                ToolTip="Drag and drop FIT files here, either raw or as ZIP files.">
        <ContentControl FontSize="68" Content="{StaticResource OpenFileIcon}" />
        <TextBlock Text="Drop files here"
                   FontStyle="Italic"
                   Foreground="Gray"
                   FontSize="18"
                   Opacity="0.5"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />
    </StackPanel>
    <!--#endregion Icons-->

    <Duration x:Key="MouseOverAnimationDuration">0:0:0.2</Duration>

    <Color x:Key="MouseOverTextColor">White</Color>
    <SolidColorBrush x:Key="MouseOverTextBrush"
                     Color="{StaticResource MouseOverTextColor}"
                     Opacity="1" />
    <Color x:Key="TextColor">Black</Color>
    <SolidColorBrush x:Key="TextBrush"
                     Color="{StaticResource TextColor}"
                     Opacity="1" />
    <Color x:Key="ExtraFileItemAutoRenamingEnabledBackgroundColor">#ade79c</Color>
    <SolidColorBrush x:Key="FileItemAutoRenamingEnabledBackgroundBrush"
                     Color="{StaticResource ExtraFileItemAutoRenamingEnabledBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="ExtraFileItemManualRenamingEnabledBackgroundColor">#e7d89c</Color>
    <SolidColorBrush x:Key="FileItemManualRenamingEnabledBackgroundBrush"
                     Color="{StaticResource ExtraFileItemManualRenamingEnabledBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="ExtraFileItemDefaultBackgroundColor">#9bc3c5</Color>
    <SolidColorBrush x:Key="ExtraFileItemDefaultBackgroundBrush"
                     Color="{StaticResource ExtraFileItemDefaultBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="ExtraFileItemButtonBackgroundColor">LightSteelBlue</Color>
    <Color x:Key="ExtraFileItemButtonHighlightColor">SteelBlue</Color>
    <SolidColorBrush x:Key="ExtraFileItemButtonBackgroundBrush"
                     Color="{StaticResource ExtraFileItemButtonBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="DefaultListItemBackgroundColor">#9bc3c5</Color>
    <SolidColorBrush x:Key="DefaultListItemBackgroundBrush"
                     Color="{StaticResource DefaultListItemBackgroundColor}"
                     Opacity="0.8" />
    <Color x:Key="DefaultListItemHighlightColor">PapayaWhip</Color>
    <SolidColorBrush x:Key="DefaultListItemHighlightBrush"
                     Color="{StaticResource DefaultListItemHighlightColor}"
                     Opacity="0.8" />

    <Style TargetType="Button">
        <Style.Setters>
            <Setter Property="Background"
                    Value="{StaticResource ExtraFileItemButtonBackgroundBrush}" />
            <Setter Property="Foreground"
                    Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness"
                    Value="0" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Content="{TemplateBinding Content}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style.Setters>

        <Style.Triggers>
            <Trigger Property="IsMouseOver"
                     Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard x:Name="MouseOverStoryboard">
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                            To="{StaticResource ExtraFileItemButtonHighlightColor}"
                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                            <ColorAnimation Storyboard.TargetProperty="(Foreground).(SolidColorBrush.Color)"
                                            To="{StaticResource MouseOverTextColor}"
                                            Duration="{StaticResource MouseOverAnimationDuration}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="MouseOverStoryboard" />
                </Trigger.ExitActions>
                <!--<Setter Property="Foreground"                       
                        Value="{StaticResource MouseOverTextBrush}" />-->
            </Trigger>

            <!--<EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                        To="{StaticResource ExtraFileItemButtonHighlightColor}"
                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Storyboard.TargetProperty="(Background).(SolidColorBrush.Color)"
                                        To="{StaticResource ExtraFileItemButtonBackgroundColor}"
                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>-->
        </Style.Triggers>
    </Style>
</ResourceDictionary>
