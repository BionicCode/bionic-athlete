<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FitToCsvConverter.Controls"
                    xmlns:theme="clr-namespace:Microsoft.Windows.Themes;assembly=PresentationFramework.Aero2">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/FitToCsvConverter.Controls;component/Resources/Styles/ViewRessources.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type local:ToolBarButton}">
        <Setter Property="Background"
                Value="{StaticResource DarkThemeButtonBackgroundBrush}" />
        <Setter Property="Foreground"
                Value="{StaticResource DarkThemeTextBrush}" />
        <Setter Property="BorderBrush"
                Value="{StaticResource DarkThemeButtonBorderBrush}" />
        <Setter Property="BorderThickness"
                Value="1" />
        <Setter Property="Padding"
                Value="5" />
        <!--<Setter Property="HorizontalContentAlignment"
                Value="Stretch" />
        <Setter Property="VerticalContentAlignment"
                Value="Center" />-->
        <Setter Property="HorizontalAlignment"
                Value="Stretch" />
        <Setter Property="VerticalAlignment"
                Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ToolBarButton}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource DarkThemeHoveredButtonBackgroundColor}"
                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource DarkThemeHoveredButtonBorderColor}"
                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource DarkThemePressedButtonBackgroundColor}"
                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource DarkThemePressedButtonBorderColor}"
                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="{StaticResource DarkThemeDisabledButtonBackgroundColor}"
                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                        <ColorAnimation Storyboard.TargetName="Border"
                                                        Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource DarkThemeDisabledButtonBorderColor}"
                                                        Duration="{StaticResource MouseOverAnimationDuration}" />
                                        <DoubleAnimation Storyboard.TargetName="Border"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.5"
                                                         Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <Grid Margin="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--<Viewbox x:Name="PART_ContentPresenterViewBox"
                                     Grid.Row="0"
                                     Grid.RowSpan="2"
                                     Margin="{TemplateBinding Padding}"
                                     StretchDirection="Both"
                                     Stretch="Fill">
                                <ContentPresenter x:Name="PART_ContentPresenter" />
                            </Viewbox>-->
                            <Border x:Name="PART_ContentPresenterViewBox"
                                    Grid.Row="0"
                                    Grid.RowSpan="2"
                                    Margin="{TemplateBinding Padding}">
                                <ContentPresenter x:Name="PART_ContentPresenter" />
                            </Border>
                            
                            <Border x:Name="PART_LabelBorder"
                                    Grid.Row="1"
                                    Panel.ZIndex="10"
                                    Opacity="0"
                                    Background="#656565"
                                    CornerRadius="{StaticResource CornerRadius}"
                                    VerticalAlignment="Center"
                                    Padding="5,0">
                                <!--<Viewbox>-->
                                <TextBlock x:Name="PART_Label"
                                           Text="{TemplateBinding LabelText}"
                                           HorizontalAlignment="Center"
                                           FontSize="{TemplateBinding LabelFontSize}" />
                                <!--</Viewbox>-->
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>